# Copy to .env (run.sh setup does this automatically) and fill in only what you need.
# ALL of training/eval/quantize works with NONE of these set — they are optional.
# .env is git-ignored. Never commit real keys.

# --- Weights & Biases (optional: live reward/entropy/accuracy curves) ---------
# Leave WANDB_MODE=disabled to skip logging. To log: set the key AND WANDB_MODE=online.
WANDB_API_KEY=
WANDB_MODE=disabled
WANDB_PROJECT=adaptivethink-rl

# --- Hugging Face (optional) --------------------------------------------------
# Only needed to (a) download a gated model, or (b) push trained adapters to the Hub.
# Qwen2.5-Instruct + GSM8K/StrategyQA are public, so this is NOT required to train.
HF_TOKEN=

# --- Teacher-label providers (ONLY for the legacy verifier-distillation path) --
# Not used by the Strategy-1 RL core. Set one only if you run scripts/02 teacher labels.
DEEPINFRA_API_KEY=
OPENAI_API_KEY=
TOGETHER_API_KEY=
